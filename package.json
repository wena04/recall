{
  "name": "second-brain-recall",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "client:dev": "vite --config web/vite.config.ts",
    "build": "tsc -b && vite build --config web/vite.config.ts",
    "lint": "eslint .",
    "preview": "vite preview --config web/vite.config.ts",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "agent:start": "npm run start -w imessage-agent",
    "agent:dev": "npm run dev -w imessage-agent",
    "agent:test:imessage": "npm run test:imessage -w imessage-agent",
    "agent:test:send": "npm run test:send -w imessage-agent",
    "agent:test:watch": "npm run test:watch -w imessage-agent",
    "agent:scan-all": "npm run scan-all -w imessage-agent",
    "agent:notify-poll": "npm run notify-poll -w imessage-agent",
    "demo:load": "tsx demo/load-fixtures.ts",
    "dev:ensure-user": "tsx scripts/ensure-dev-auth-user.ts",
    "dev:smoke-api": "tsx scripts/smoke-api.ts",
    "ingest:local": "tsx scripts/bulk-ingest-local.ts",
    "ingest:parse-cn": "python3 scripts/ingest/parse_cn_us_posts.py",
    "ingest:seed": "tsx scripts/ingest/seed-posts.ts"
  },
  "dependencies": {
    "@notionhq/client": "^5.14.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.99.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.3.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
