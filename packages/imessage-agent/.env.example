# Photon / iMessage (see packages/imessage-agent/README.md)
RECALL_TRIGGER=recall
# Messages pulled per recall (this thread only). Not a date range — last N messages in that thread.
MAX_MESSAGES=400

# Multi-chat: say "recall all" in iMessage (needs RECALL_SCAN_ALL_CHATS=true) OR run CLI: npm run agent:scan-all
# RECALL_SCAN_ALL_CHATS=true
# RECALL_MAX_CHATS_SCAN=15
# RECALL_MESSAGES_PER_CHAT_SCAN=120
# RECALL_INGEST_DELAY_MS=1500
# Per-thread logs: raw vs text message counts, skip reasons (npm run agent:scan-all or "recall all")
# RECALL_SCAN_DEBUG=true

# If set (comma-separated), ONLY group chats whose *display name* contains one of these strings respond.
# Example for USC course groups: INFO 340,INFO 330,INFO330
# Leave empty = any DM or group can say "recall"
RECALL_GROUP_NAME_CONTAINS=

# Extra line(s) sent to MiniMax as context (demo pitch, course names)
RECALL_DEMO_HINT=Likely USC INFO 340 or INFO 330 group project chat — extract courses, deadlines, tools, and texting style.

# How often to refresh chat display names (ms)
CHAT_LABEL_REFRESH_MS=300000

# After fetching history, POST transcript → MiniMax → Supabase (run `npm run dev` at repo root)
SECOND_BRAIN_INGEST_ON_RECALL=true
SECOND_BRAIN_API_URL=http://localhost:3001
SECOND_BRAIN_USER_ID=
RECALL_IMESSAGE_TARGET=
