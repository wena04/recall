# MiniMax (primary AI engine)
# Key from https://platform.minimax.io — used as x-api-key (Anthropic compat) and Bearer (legacy vision).
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Text extraction: Anthropic-compatible Messages API (recommended; models M2.x — see platform docs).
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_RAG_MODEL=M2-her
# Vision / native chatcompletion_v2 + embeddings (Anthropic host has no /embeddings — do not point legacy at /anthropic).
MINIMAX_LEGACY_BASE_URL=https://api.minimax.io/v1
# Optional override for embeddings only (defaults to MINIMAX_LEGACY_BASE_URL, then https://api.minimax.io/v1).
# MINIMAX_EMBEDDINGS_BASE_URL=https://api.minimax.io/v1
# Optional: older envs only; avoid setting this to .../anthropic or vision + embeddings break.
# MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_LEGACY_MODEL=MiniMax-M2.7
# Optional: location ping iMessage copy (defaults to MINIMAX_MODEL / M2.7)
# MINIMAX_LOCATION_MODEL=MiniMax-M2.7

# Supabase — server (Express / demo scripts). Never expose service_role to the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=

# Supabase — browser (Vite). Use the anon key from Dashboard → API Keys (JWT “anon legacy”),
# or the publishable key if your project uses that with supabase-js.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Shared secret: browser uses Supabase JWT; Mac agent + CLI use Bearer RECALL_AGENT_SECRET (same value here and on Vercel).
# Generate a long random string. Required for /api/* except /api/health.
RECALL_AGENT_SECRET=

# Optional local API port
# PORT=3001

# Dev only: skip dashboard login (user id must exist in Supabase Auth → Users)
# VITE_DEV_BYPASS_AUTH=true
# VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000000
# When bypass is on, set VITE_RECALL_AGENT_SECRET to the same value as RECALL_AGENT_SECRET so /api/* works.
# VITE_RECALL_AGENT_SECRET=

# Photon iMessage agent (macOS) — separate file: packages/imessage-agent/.env
# See packages/imessage-agent/README.md — npm run agent:test:imessage then npm run agent:start

# --- Vercel (Dashboard → Project → Settings → Environment Variables) ---
# Add the same server + MiniMax secrets as above (SUPABASE_*, MINIMAX_*).
# Also add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY for the client build (anon key is public; never put SUPABASE_SERVICE_KEY in VITE_*).
# Supabase Auth → URL configuration: Site URL = https://YOUR-APP.vercel.app
# Redirect URLs: https://YOUR-APP.vercel.app/**  (and http://localhost:5173/** for local)
# Set RECALL_AGENT_SECRET on Vercel too (same as local). iMessage agent on your Mac: SECOND_BRAIN_API_URL=https://YOUR-APP.vercel.app  (WebSocket still local via SECOND_BRAIN_WS_URL)
# Backend source: `server/api-backend/` (Express). Vercel: esbuild → `api/index.mjs` (one serverless function).
